@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập - Hệ thống Thư viện";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #1f4068 0%, #162447 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Roboto', sans-serif;
            margin: 0;
            padding: 20px;
        }

        .login-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            overflow: hidden;
            background: #ffffff;
            width: 100%;
            max-width: 450px;
        }

        .login-header-premium {
            background: linear-gradient(135deg, #1b1b2f 0%, #162447 100%);
            color: #ffffff;
            padding: 40px 30px;
            text-align: center;
            border-bottom: none;
            position: relative;
        }

        .login-header-premium h3 {
            font-weight: 700;
            letter-spacing: 1.5px;
            font-size: 26px;
            margin-bottom: 8px;
            color: #ffffff;
        }

        .login-header-premium p {
            color: #f1c40f;
            margin-bottom: 0;
            font-weight: 500;
            font-size: 14px;
        }

        .login-body {
            padding: 40px 35px;
        }

        .form-floating {
            position: relative;
            margin-bottom: 20px;
        }

        .form-control-premium {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 15px;
            transition: all 0.3s ease;
            background-color: #f8fafc;
            height: 58px;
        }

        .form-control-premium:focus {
            border-color: #f1c40f;
            box-shadow: 0 0 0 4px rgba(241, 196, 15, 0.15);
            background-color: #ffffff;
        }

        .btn-login-premium {
            background: linear-gradient(135deg, #f1c40f 0%, #f39c12 100%);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            font-size: 16px;
            color: #111111;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(241, 196, 15, 0.3);
            width: 100%;
        }

        .btn-login-premium:hover {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(241, 196, 15, 0.4);
            color: #111111;
        }

        .btn-login-premium:active {
            transform: translateY(1px);
        }

        .login-footer-premium {
            background: #111111;
            color: rgba(255, 255, 255, 0.6);
            padding: 25px 20px;
            text-align: center;
            font-size: 13px;
        }

        .login-footer-premium a {
            color: rgba(255, 255, 255, 0.6);
            transition: color 0.3s ease, transform 0.3s ease;
            display: inline-block;
            text-decoration: none;
        }

        .login-footer-premium a:hover {
            color: #f1c40f;
            transform: scale(1.15);
        }

        .test-account-box {
            background-color: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            padding: 15px;
            font-size: 13px;
            color: #475569;
            margin-top: 25px;
            text-align: center;
        }

        .test-account-box i {
            color: #e67e22;
        }

        .brand-icon-box {
            width: 65px;
            height: 65px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px auto;
            font-size: 26px;
            color: #f1c40f;
            border: 2px solid rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header-premium">
            <div class="brand-icon-box">
                <i class="fas fa-book-open"></i>
            </div>
            <h3>ĐĂNG NHẬP</h3>
            <p>Hệ Thống Quản Lý Thư Viện Hiện Đại</p>
        </div>
        <div class="login-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center" role="alert">
                    <i class="fas fa-exclamation-circle me-2 fs-5"></i>
                    <div class="small">@ViewBag.Error</div>
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="form-floating mb-3">
                    <input type="text" class="form-control form-control-premium" id="username" name="username" placeholder="Tên đăng nhập" required autocomplete="username">
                    <label for="username"><i class="fas fa-user me-2"></i>Tên đăng nhập</label>
                </div>
                <div class="form-floating mb-4">
                    <input type="password" class="form-control form-control-premium" id="password" name="password" placeholder="Mật khẩu" required autocomplete="current-password">
                    <label for="password"><i class="fas fa-lock me-2"></i>Mật khẩu</label>
                </div>
                <button type="submit" class="btn btn-login-premium">ĐĂNG NHẬP <i class="fas fa-sign-in-alt ms-1"></i></button>
            </form>

            <div class="mt-4 text-center">
                <span class="text-secondary small">Chưa có tài khoản?</span>
                <a href="/Auth/Register" class="text-primary fw-bold text-decoration-none small ms-1">Đăng ký độc giả ngay <i class="fas fa-arrow-right small"></i></a>
            </div>

            <div class="test-account-box">
                <p class="mb-1 fw-bold"><i class="fas fa-info-circle me-1"></i> Tài khoản trải nghiệm nhanh:</p>
                <span class="small text-secondary">Tài khoản: <strong class="text-dark">docgia01</strong> | Mật khẩu: <strong class="text-dark">123456</strong></span>
            </div>
        </div>
        <div class="login-footer-premium">
            <p class="mb-2">© 2026 Hệ Thống Thư Viện Trực Tuyến. All rights reserved.</p>
            <div class="mb-3 d-flex justify-content-center gap-3">
                <a href="#"><i class="fab fa-facebook-f"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-youtube"></i></a>
            </div>
            <p class="mb-0 small"><i class="fas fa-map-marker-alt me-2 text-warning"></i>123 Đường ABC, Quận 1, TP. Hồ Chí Minh</p>
        </div>
    </div>
</body>
</html>
