@{
    Layout = null;
    ViewData["Title"] = "Đăng ký Độc giả - Hệ thống Thư viện";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #1f4068 0%, #162447 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Roboto', sans-serif;
            margin: 0;
            padding: 20px;
        }

        .register-container {
            width: 100%;
            max-width: 800px;
        }

        .register-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            overflow: hidden;
            background: #ffffff;
        }

        .register-header-premium {
            background: linear-gradient(135deg, #1b1b2f 0%, #162447 100%);
            color: #ffffff;
            padding: 30px 20px;
            text-align: center;
            border-bottom: none;
        }

        .register-header-premium h3 {
            font-weight: 700;
            letter-spacing: 1.5px;
            font-size: 26px;
            margin-bottom: 6px;
            color: #ffffff;
        }

        .register-header-premium p {
            color: #f1c40f;
            margin-bottom: 0;
            font-weight: 500;
            font-size: 13px;
        }

        .register-body {
            padding: 35px;
        }

        .form-floating {
            position: relative;
            margin-bottom: 15px;
        }

        .form-control-premium {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: #f8fafc;
            height: 58px;
        }

        .form-control-premium:focus {
            border-color: #f1c40f;
            box-shadow: 0 0 0 4px rgba(241, 196, 15, 0.15);
            background-color: #ffffff;
        }

        .form-select-premium {
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: #f8fafc;
            height: 58px;
        }

        .form-select-premium:focus {
            border-color: #f1c40f;
            box-shadow: 0 0 0 4px rgba(241, 196, 15, 0.15);
            background-color: #ffffff;
        }

        .btn-register-premium {
            background: linear-gradient(135deg, #f1c40f 0%, #f39c12 100%);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            font-size: 16px;
            color: #111111;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(241, 196, 15, 0.3);
            width: 100%;
        }

        .btn-register-premium:hover {
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(241, 196, 15, 0.4);
            color: #111111;
        }

        .btn-register-premium:active {
            transform: translateY(1px);
        }

        .register-footer-premium {
            background: #111111;
            color: rgba(255, 255, 255, 0.6);
            padding: 25px 20px;
            text-align: center;
            font-size: 13px;
        }

        .register-footer-premium a {
            color: rgba(255, 255, 255, 0.6);
            transition: color 0.3s ease, transform 0.3s ease;
            display: inline-block;
            text-decoration: none;
        }

        .register-footer-premium a:hover {
            color: #f1c40f;
            transform: scale(1.15);
        }

        .brand-icon-box {
            width: 55px;
            height: 55px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px auto;
            font-size: 22px;
            color: #f1c40f;
            border: 2px solid rgba(255, 255, 255, 0.2);
        }

        .section-title {
            font-size: 13px;
            font-weight: 700;
            color: #1f4068;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            border-bottom: 2px solid #1f4068;
            padding-bottom: 4px;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="card register-card">
            <div class="register-header-premium">
                <div class="brand-icon-box">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h3>ĐĂNG KÝ ĐỘC GIẢ</h3>
                <p>Trở thành thành viên để mượn sách trực tuyến dễ dàng và tiện lợi</p>
            </div>
            <div class="register-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-circle me-2 fs-5"></i>
                        <div class="small">@ViewBag.Error</div>
                    </div>
                }

                <form asp-action="Register" method="post">
                    <div class="row">
                        <!-- Left Column: Account Info -->
                        <div class="col-md-6 mb-4 mb-md-0">
                            <div class="section-title"><i class="fas fa-key me-2"></i>Thông tin tài khoản</div>
                            
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control form-control-premium" id="username" name="username" placeholder="Tên đăng nhập" required autocomplete="username">
                                <label for="username"><i class="fas fa-user me-2"></i>Tên đăng nhập *</label>
                            </div>
                            <div class="form-floating mb-3">
                                <input type="password" class="form-control form-control-premium" id="password" name="password" placeholder="Mật khẩu" required autocomplete="new-password">
                                <label for="password"><i class="fas fa-lock me-2"></i>Mật khẩu *</label>
                            </div>
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control form-control-premium" id="hoten" name="hoten" placeholder="Họ và tên" required>
                                <label for="hoten"><i class="fas fa-id-card me-2"></i>Họ và tên *</label>
                            </div>
                            <div class="form-floating">
                                <input type="email" class="form-control form-control-premium" id="email" name="email" placeholder="Email">
                                <label for="email"><i class="fas fa-envelope me-2"></i>Email</label>
                            </div>
                        </div>

                        <!-- Right Column: Personal Info -->
                        <div class="col-md-6">
                            <div class="section-title"><i class="fas fa-id-card-alt me-2"></i>Thông tin cá nhân</div>

                            <div class="form-floating mb-3">
                                <input type="text" class="form-control form-control-premium" id="sodienthoai" name="sodienthoai" placeholder="Số điện thoại">
                                <label for="sodienthoai"><i class="fas fa-phone me-2"></i>Số điện thoại</label>
                            </div>
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control form-control-premium" id="socccd" name="socccd" placeholder="Số CCCD">
                                <label for="socccd"><i class="fas fa-address-card me-2"></i>Số CCCD</label>
                            </div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="form-floating mb-3">
                                        <select class="form-select form-select-premium" id="gioitinh" name="gioitinh">
                                            <option value="Nam">Nam</option>
                                            <option value="Nữ">Nữ</option>
                                            <option value="Khác">Khác</option>
                                        </select>
                                        <label for="gioitinh"><i class="fas fa-venus-mars me-2"></i>Giới tính</label>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="form-floating mb-3">
                                        <input type="date" class="form-control form-control-premium" id="ngaysinh" name="ngaysinh" placeholder="Ngày sinh">
                                        <label for="ngaysinh"><i class="fas fa-calendar-alt me-2"></i>Ngày sinh</label>
                                    </div>
                                </div>
                            </div>
                            <div class="form-floating">
                                <input type="text" class="form-control form-control-premium" id="diachi" name="diachi" placeholder="Địa chỉ">
                                <label for="diachi"><i class="fas fa-map-marker-alt me-2"></i>Địa chỉ</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-register-premium">ĐĂNG KÝ TÀI KHOẢN <i class="fas fa-user-plus ms-1"></i></button>
                    </div>
                </form>

                <div class="mt-4 text-center">
                    <span class="text-secondary small">Đã có tài khoản?</span>
                    <a href="/Auth/Login" class="text-primary fw-bold text-decoration-none small ms-1">Quay lại Đăng nhập ngay <i class="fas fa-arrow-right small"></i></a>
                </div>
            </div>
            <div class="register-footer-premium">
                <p class="mb-2">© 2026 Hệ Thống Thư Viện Trực Tuyến. All rights reserved.</p>
                <div class="mb-3 d-flex justify-content-center gap-3">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
                <p class="mb-0 small"><i class="fas fa-map-marker-alt me-2 text-warning"></i>123 Đường ABC, Quận 1, TP. Hồ Chí Minh</p>
            </div>
        </div>
    </div>
</body>
</html>
