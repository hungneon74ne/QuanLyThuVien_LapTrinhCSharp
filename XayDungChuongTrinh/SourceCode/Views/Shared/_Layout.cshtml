<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thư viện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <!-- SweetAlert2 CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            background: #f8f9fa;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-family: 'Roboto', sans-serif;
        }
        .main-content {
            flex: 1;
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Roboto', sans-serif;
        }
        .navbar-custom {
            background: rgba(18, 18, 20, 0.97) !important;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.25) !important;
            padding: 12px 0;
            transition: all 0.3s ease;
        }
        .navbar-brand {
            padding: 0 !important;
            transition: all 0.3s ease;
        }
        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            user-select: none;
        }
        .logo-icon-box {
            position: relative;
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #f1c40f 0%, #f39c12 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #121214 !important;
            font-size: 1.25rem;
            box-shadow: 0 4px 15px rgba(241, 196, 15, 0.25);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .navbar-brand:hover .logo-icon-box {
            transform: scale(1.08) rotate(-6deg);
            box-shadow: 0 6px 20px rgba(241, 196, 15, 0.45);
        }
        .logo-text-main {
            font-size: 1.35rem;
            font-weight: 900;
            letter-spacing: 1.5px;
            color: #ffffff !important;
            font-family: 'Roboto', sans-serif;
            text-transform: uppercase;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }
        .logo-text-sub {
            color: #f1c40f;
            background: linear-gradient(120deg, #f1c40f 0%, #f39c12 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 900;
            margin-left: 2px;
        }
        .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
            font-size: 1.02rem;
            margin: 0 12px;
            position: relative;
            padding: 6px 0 !important;
            transition: color 0.3s ease;
        }
        .nav-link:not(.profile-dropdown-btn)::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: #f1c40f;
            transition: width 0.3s ease;
            border-radius: 2px;
        }
        .nav-link:hover {
            color: #ffffff !important;
        }
        .nav-link:not(.profile-dropdown-btn):hover::after {
            width: 100%;
        }
        .nav-search-input {
            background: rgba(255, 255, 255, 0.05) !important;
            color: #ffffff !important;
            border: 1.5px solid #f1c40f !important;
            padding-left: 45px !important;
            transition: all 0.3s ease !important;
            border-radius: 30px !important;
            font-size: 0.95rem;
        }
        .nav-search-input::placeholder {
            color: rgba(255, 255, 255, 0.45);
        }
        .nav-search-input:focus {
            background: rgba(255, 255, 255, 0.12) !important;
            border-color: #f39c12 !important;
            box-shadow: 0 0 15px rgba(241, 196, 15, 0.3) !important;
        }
        .nav-search-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #f1c40f !important;
            transition: color 0.3s ease;
            pointer-events: none;
            z-index: 5;
        }
        .position-relative:focus-within .nav-search-icon {
            color: #f39c12 !important;
        }
        .profile-dropdown-btn {
            background: rgba(255, 255, 255, 0.08) !important;
            border: none !important;
            border-radius: 30px !important;
            padding: 8px 20px !important;
            color: #ffffff !important;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .profile-dropdown-btn:hover, .profile-dropdown-btn:focus {
            background: rgba(255, 255, 255, 0.18) !important;
            color: #ffffff !important;
        }
        .dropdown-menu {
            border: none !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
            border-radius: 12px !important;
            padding: 8px !important;
        }
        .dropdown-item {
            border-radius: 8px !important;
            padding: 8px 16px !important;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .dropdown-item:hover {
            background: rgba(0, 51, 102, 0.05) !important;
            color: #003366 !important;
        }
        .dropdown-item.text-danger:hover {
            background: rgba(231, 76, 60, 0.05) !important;
            color: #e74c3c !important;
        }
        .nav-bell-link {
            background: rgba(255, 255, 255, 0.08);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255, 255, 255, 0.15);
            transition: all 0.3s ease;
            color: #ffffff !important;
            position: relative;
        }
        .nav-bell-link:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: scale(1.05);
        }
        .nav-bell-badge {
            font-size: 9px !important;
            padding: 4px 6px !important;
            border: 2px solid rgba(0, 31, 63, 0.96) !important;
        }
        .btn-nav-login {
            background: transparent !important;
            border: none !important;
            color: #f1c40f !important;
            padding: 8px 16px !important;
            font-weight: 700 !important;
            font-size: 1.02rem !important;
            transition: all 0.2s ease !important;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            box-shadow: none !important;
            text-decoration: none !important;
        }
        .btn-nav-login:hover {
            color: #ffffff !important;
            background: transparent !important;
            box-shadow: none !important;
            transform: translateY(-1px);
            text-decoration: none !important;
        }

        /* Cohesive Reader Pages Theme (Charcoal Dark + Gold Accent) */
        .card-header-premium {
            background: rgba(18, 18, 20, 0.98) !important;
            color: #ffffff !important;
            border-bottom: 2.5px solid #f1c40f !important; /* Premium Gold border */
            font-weight: 700 !important;
        }
        .reader-welcome-banner {
            background: linear-gradient(135deg, #121214 0%, #1e293b 100%) !important;
            border-left: 5px solid #f1c40f !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
            border-radius: 16px !important;
        }
        .reader-welcome-banner h2 {
            color: #ffffff !important;
        }
        .reader-welcome-banner p {
            color: rgba(255, 255, 255, 0.85) !important;
        }
        .reader-welcome-banner strong {
            color: #f1c40f !important; /* Gold highlights */
        }
        .reader-stat-card-gold {
            border-left: 5px solid #f1c40f !important;
            border-radius: 16px !important;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.03) !important;
        }
        .reader-stat-card-blue {
            border-left: 5px solid #3498db !important;
            border-radius: 16px !important;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.03) !important;
        }
        .reader-stat-card-red {
            border-left: 5px solid #e74c3c !important;
            border-radius: 16px !important;
            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.03) !important;
        }
        /* Active Link gold coloring in sidebars */
        .list-group-item-active-gold {
            background: rgba(241, 196, 15, 0.06) !important;
            border-left: 4px solid #f1c40f !important;
        }
        .list-group-item-active-gold a {
            color: #f39c12 !important;
            font-weight: 700 !important;
        }
        /* Input borders */
        .form-control-premium:focus {
            border-color: #f1c40f !important;
            box-shadow: 0 0 0 0.25rem rgba(241, 196, 15, 0.15) !important;
        }
        /* Buttons outline gold */
        .btn-premium-gold {
            background: transparent !important;
            border: 1.5px solid #f1c40f !important;
            color: #f1c40f !important;
            font-weight: 600 !important;
            transition: all 0.3s ease !important;
        }
        .btn-premium-gold:hover {
            background: #f1c40f !important;
            color: #121214 !important;
            box-shadow: 0 4px 15px rgba(241, 196, 15, 0.2) !important;
        }

        .main-container {
            background: #f8f9fa;
            padding: 40px;
        }
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 60px 0;
            border-radius: 15px;
            margin-bottom: 40px;
        }
        .book-card {
            border: none;
            border-radius: 0;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s, box-shadow 0.3s;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .book-card .card-body {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .book-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }
        .book-card img {
            height: 400px;
            object-fit: cover;
            width: 100%;
        }
        .book-card .card-title {
            min-height: 50px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .btn-custom {
            background: #333;
            border: none;
            color: white;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-custom:hover {
            background: #555;
            transform: translateY(-2px);
            color: white;
        }
        .feature-icon {
            font-size: 2.5rem;
            color: #007bff;
            margin-bottom: 15px;
        }
        footer {
            background: rgba(255, 255, 255, 0.95);
            color: #333;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <div class="logo-wrapper">
                    <div class="logo-icon-box">
                        <i class="fas fa-book-open"></i>
                    </div>
                    <span class="logo-text-main">THƯ<span class="logo-text-sub">VIỆN</span></span>
                </div>
            </a>
            <button class="navbar-toggler border-0 text-white" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" style="box-shadow: none;">
                <i class="fas fa-bars fs-4" style="color: white;"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Books">Sách</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/About">Giới thiệu</a>
                    </li>
                </ul>
                <form class="d-flex me-3 position-relative mb-2 mb-lg-0" action="/Home/Books" method="get">
                    <div class="position-relative" style="width: 260px;">
                        <input class="form-control nav-search-input" type="search" placeholder="Tìm kiếm sách..." name="keyword" style="padding-right: 20px;">
                        <i class="fas fa-search nav-search-icon"></i>
                    </div>
                </form>
                <ul class="navbar-nav align-items-center">
                    @if (Context.Session.GetString("MaNguoiDung") != null)
                    {
                        <li class="nav-item mb-2 mb-lg-0">
                            <a class="nav-bell-link" href="/DocGia/NhanThongBao">
                                <i class="fas fa-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger nav-bell-badge">
                                    @(ViewBag.UnreadCount ?? 0)
                                </span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle profile-dropdown-btn" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle fs-5"></i> @Context.Session.GetString("HoTen")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg mt-2">
                                <li><a class="dropdown-item" href="/DocGia/Dashboard"><i class="fas fa-columns me-2 text-primary"></i>Trang Độc Giả</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/Auth/Logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn-nav-login" href="/Auth/Login">Đăng nhập <i class="fas fa-sign-in-alt"></i></a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="main-content">
        <div class="container" style="padding-top: 100px; padding-bottom: 30px;">
            @RenderBody()
        </div>
    </div>

    <footer class="py-5 mt-5" style="background: #333; color: white;">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">Về Thư viện</h5>
                    <p class="text-white-50">Thư viện trực tuyến cung cấp hàng ngàn cuốn sách đa dạng thể loại cho bạn đọc và khám phá.</p>
                    <div class="mt-3">
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-white-50"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">Liên kết nhanh</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="/" class="text-white-50 text-decoration-none">Trang chủ</a></li>
                        <li class="mb-2"><a href="/Home/Books" class="text-white-50 text-decoration-none">Sách</a></li>
                        <li class="mb-2"><a href="/Home/About" class="text-white-50 text-decoration-none">Giới thiệu</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h5 class="fw-bold mb-3">Liên hệ</h5>
                    <p class="text-white-50 mb-2"><i class="fas fa-map-marker-alt me-2"></i>123 Đường ABC, Quận 1, TP.HCM</p>
                    <p class="text-white-50 mb-2"><i class="fas fa-phone me-2"></i>(028) 1234 5678</p>
                    <p class="text-white-50 mb-2"><i class="fas fa-envelope me-2"></i>info@thuvien.vn</p>
                </div>
            </div>
            <hr class="my-4 border-secondary">
            <div class="text-center text-white-50">
                <p class="mb-0">&copy; 2026 Thư viện. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Cấu hình Toast chung toàn hệ thống
        const GlobalToast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });
    </script>

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            GlobalToast.fire({
                icon: 'success',
                title: '@Html.Raw(TempData["SuccessMessage"])'
            });
        </script>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            GlobalToast.fire({
                icon: 'error',
                title: '@Html.Raw(TempData["ErrorMessage"])'
            });
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
