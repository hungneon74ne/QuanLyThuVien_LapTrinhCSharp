@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Carousel Slider - Full Width -->
<div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" style="margin-bottom: 40px;">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=1200&h=600&fit=crop" class="d-block w-100" alt="Library" style="height: 600px; object-fit: cover;">
            <div class="carousel-caption d-none d-md-block">
                <h3>Thư viện - Nơi tri thức bắt đầu</h3>
                <p>Khám phá hàng ngàn cuốn sách hay và bổ ích</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1521587760476-6c12a4b040da?w=1200&h=600&fit=crop" class="d-block w-100" alt="Books" style="height: 600px; object-fit: cover;">
            <div class="carousel-caption d-none d-md-block">
                <h3>Sách đa dạng thể loại</h3>
                <p>Từ văn học đến khoa học, tất cả đều có tại đây</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&h=600&fit=crop" class="d-block w-100" alt="Reading" style="height: 600px; object-fit: cover;">
            <div class="carousel-caption d-none d-md-block">
                <h3>Không gian đọc sách yên tĩnh</h3>
                <p>Tận hưởng không gian thoải mái để đọc và học tập</p>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<div class="main-container">
    <!-- Features -->
    <div class="row mb-5">
        <div class="col-md-4 text-center">
            <div class="feature-item p-4">
                <i class="fas fa-book-reader feature-icon"></i>
                <h4>Thư viện phong phú</h4>
                <p class="text-muted">Hàng ngàn đầu sách đa dạng thể loại</p>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="feature-item p-4">
                <i class="fas fa-laptop feature-icon"></i>
                <h4>Mượn online</h4>
                <p class="text-muted">Đăng ký mượn sách qua mạng dễ dàng</p>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="feature-item p-4">
                <i class="fas fa-headset feature-icon"></i>
                <h4>Hỗ trợ 24/7</h4>
                <p class="text-muted">Luôn sẵn sàng hỗ trợ bạn mọi lúc</p>
            </div>
        </div>
    </div>

    <!-- Featured Books -->
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold"><i class="fas fa-star text-warning me-2"></i>Sách nổi bật</h2>
            <a href="/Home/Books">Xem tất cả <i class="fas fa-arrow-right ms-2"></i></a>
        </div>

        <div class="row">
            @if (ViewBag.FeaturedBooks != null && ((dynamic)ViewBag.FeaturedBooks).Count > 0)
            {
                @foreach (var sach in ViewBag.FeaturedBooks)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card book-card">
                            @if (!string.IsNullOrEmpty(sach.HinhAnh))
                            {
                                <img src="@sach.HinhAnh" class="card-img-top" alt="@sach.TenSach">
                            }
                            else
                            {
                                <div style="height: 400px; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <div class="card-body">
                                <h5 class="card-title fw-bold">@sach.TenSach</h5>
                                <p class="card-text text-muted mb-2">@sach.TacGia?.TenTacGia</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                    <small class="text-muted">@sach.GiaTien.ToString("N0") đ</small>
                                </div>
                                <div class="mt-3">
                                    <a href="/DocGia/ChiTietSach/@sach.MaSach" class="text-decoration-none">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có sách nào</p>
                </div>
            }
        </div>
    </div>

    <!-- Books by Category: Văn học -->
    <div class="mb-5">
        <h2 class="fw-bold mb-4 text-center py-3" style="background: #e9ecef; font-size: 1.8rem; letter-spacing: 2px; text-transform: uppercase; font-family: 'Playfair Display', serif;">Văn Học</h2>
        <div class="row">
            @if (ViewBag.VanHocBooks != null && ((dynamic)ViewBag.VanHocBooks).Count > 0)
            {
                @foreach (var sach in ViewBag.VanHocBooks)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card book-card">
                            @if (!string.IsNullOrEmpty(sach.HinhAnh))
                            {
                                <img src="@sach.HinhAnh" class="card-img-top" alt="@sach.TenSach">
                            }
                            else
                            {
                                <div style="height: 400px; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <div class="card-body">
                                <h5 class="card-title fw-bold">@sach.TenSach</h5>
                                <p class="card-text text-muted mb-2">@sach.TacGia?.TenTacGia</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                    <small class="text-muted">@sach.GiaTien.ToString("N0") đ</small>
                                </div>
                                <div class="mt-3">
                                    <a href="/DocGia/ChiTietSach/@sach.MaSach" class="text-decoration-none">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có sách văn học nào</p>
                </div>
            }
        </div>
    </div>

    <!-- Books by Category: Khoa học -->
    <div class="mb-5">
        <h2 class="fw-bold mb-4 text-center py-3" style="background: #e9ecef; font-size: 1.8rem; letter-spacing: 2px; text-transform: uppercase; font-family: 'Playfair Display', serif;">Khoa Học</h2>
        <div class="row">
            @if (ViewBag.KhoaHocBooks != null && ((dynamic)ViewBag.KhoaHocBooks).Count > 0)
            {
                @foreach (var sach in ViewBag.KhoaHocBooks)
                {
                    <div class="col-md-3 mb-4">
                        <div class="card book-card">
                            @if (!string.IsNullOrEmpty(sach.HinhAnh))
                            {
                                <img src="@sach.HinhAnh" class="card-img-top" alt="@sach.TenSach">
                            }
                            else
                            {
                                <div style="height: 400px; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                            <div class="card-body">
                                <h5 class="card-title fw-bold">@sach.TenSach</h5>
                                <p class="card-text text-muted mb-2">@sach.TacGia?.TenTacGia</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                    <small class="text-muted">@sach.GiaTien.ToString("N0") đ</small>
                                </div>
                                <div class="mt-3">
                                    <a href="/DocGia/ChiTietSach/@sach.MaSach" class="text-decoration-none">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có sách khoa học nào</p>
                </div>
            }
        </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center py-5" style="background: #003366; border-radius: 0;">
        <h3 class="text-white fw-bold mb-3">Bắt đầu khám phá ngay hôm nay</h3>
        <p class="text-white-50 mb-4">Đăng ký thành viên để mượn sách và nhận nhiều ưu đãi</p>
        @if (Context.Session.GetString("MaNguoiDung") == null)
        {
            <a href="/Auth/Login" class="btn btn-light btn-lg px-5 py-3 fw-bold">
                <i class="fas fa-user-plus me-2"></i>Đăng ký ngay
            </a>
        }
    </div>
</div>
