@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* Premium Hero Carousel */
    .hero-carousel-container {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 45px;
    }
    .carousel-item {
        position: relative;
    }
    .carousel-item::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.7) 100%);
        z-index: 1;
    }
    .carousel-caption {
        z-index: 2;
        bottom: 12%;
        text-shadow: 0 2px 15px rgba(0,0,0,0.4);
    }
    .carousel-caption h3 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        margin-bottom: 15px;
    }
    .carousel-caption p {
        font-size: 1.3rem;
        font-weight: 300;
        opacity: 0.95;
    }

    /* Minimalist Feature Cards */
    .feature-card {
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 14px;
        background: #fff;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 30px rgba(0, 51, 102, 0.06);
        border-color: rgba(0, 51, 102, 0.1);
    }
    .feature-icon-wrapper {
        width: 75px;
        height: 75px;
        border-radius: 50%;
        background: rgba(0, 51, 102, 0.05);
        color: #003366;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 1.9rem;
        transition: all 0.3s;
    }
    .feature-card:hover .feature-icon-wrapper {
        background: #003366;
        color: #fff;
        transform: rotateY(180deg);
    }

    /* Section Titles */
    .section-title {
        font-weight: 800;
        color: #003366;
        position: relative;
        padding-bottom: 12px;
        letter-spacing: 0.5px;
    }
    .section-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 60px;
        height: 4px;
        background: #003366;
        border-radius: 2px;
    }
    .section-title-category {
        font-size: 1.6rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #333;
        font-weight: 800;
    }

    /* Book Cards */
    .book-card {
        border-radius: 14px;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        background: #fff;
    }
    .book-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 18px 35px rgba(0, 51, 102, 0.12) !important;
    }
    .book-cover-container {
        overflow: hidden;
        position: relative;
    }
    .book-cover-img {
        height: 330px;
        object-fit: cover;
        width: 100%;
        transition: transform 0.5s ease;
    }
    .book-card:hover .book-cover-img {
        transform: scale(1.06);
    }
    .book-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #222;
        min-height: 48px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
    }

    /* Premium Call to Action */
    .cta-banner {
        background: linear-gradient(135deg, #001f3f 0%, #003366 50%, #00509e 100%);
        border-radius: 16px;
        overflow: hidden;
        position: relative;
    }
    .cta-banner::before {
        content: '';
        position: absolute;
        top: -60%; left: -10%;
        width: 350px; height: 350px;
        border-radius: 50%;
        background: rgba(255,255,255,0.035);
        pointer-events: none;
    }
    .cta-banner::after {
        content: '';
        position: absolute;
        bottom: -40%; right: -5%;
        width: 450px; height: 450px;
        border-radius: 50%;
        background: rgba(255,255,255,0.035);
        pointer-events: none;
    }
</style>

<!-- Carousel Slider - Modernized Container -->
<div class="hero-carousel-container">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=1200&h=550&fit=crop" class="d-block w-100" alt="Library" style="height: 520px; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block text-start" style="left: 8%; max-width: 550px;">
                    <h3>Thư viện trực tuyến - Khơi nguồn tri thức</h3>
                    <p class="mb-4">Khám phá hàng ngàn đầu sách thuộc mọi lĩnh vực, phục vụ học tập, nghiên cứu và giải trí.</p>
                    <a href="/Home/Books" class="btn btn-light btn-lg px-4 py-2 fw-semibold text-primary shadow-sm" style="border-radius: 8px;">Tìm Sách Ngay <i class="fas fa-arrow-right ms-2 small"></i></a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1521587760476-6c12a4b040da?w=1200&h=550&fit=crop" class="d-block w-100" alt="Books" style="height: 520px; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block" style="max-width: 650px; margin: 0 auto;">
                    <h3>Không gian văn hóa đọc đỉnh cao</h3>
                    <p class="mb-4">Liên tục cập nhật các đầu sách bán chạy nhất trong và ngoài nước.</p>
                    <a href="/Home/Books" class="btn btn-warning btn-lg px-4 py-2 fw-semibold text-white shadow-sm" style="border-radius: 8px;">Khám Phá Danh Mục</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1200&h=550&fit=crop" class="d-block w-100" alt="Reading" style="height: 520px; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block text-end" style="right: 8%; max-width: 550px; margin-left: auto;">
                    <h3>Dịch vụ mượn sách thông minh</h3>
                    <p class="mb-4">Đặt mượn trực tuyến dễ dàng, quản lý lịch sử mượn trả cực kỳ tiện lợi.</p>
                    @if (Context.Session.GetString("MaNguoiDung") == null)
                    {
                        <a href="/Auth/Login" class="btn btn-outline-light btn-lg px-4 py-2 fw-semibold" style="border-radius: 8px;">Đăng Nhập Tài Khoản</a>
                    }
                    else
                    {
                        <a href="/DocGia/Dashboard" class="btn btn-success btn-lg px-4 py-2 fw-semibold text-white shadow-sm" style="border-radius: 8px;">Tới Trang Cá Nhân</a>
                    }
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev" style="z-index: 2;">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next" style="z-index: 2;">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</div>

<div class="main-container px-2">
    <!-- Features - Modern Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="feature-card p-4 text-center h-100 border-0 shadow-sm">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-book-open"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Thư viện phong phú</h5>
                <p class="text-muted mb-0">Hàng ngàn đầu sách bản quyền phong phú nhiều thể loại luôn sẵn sàng phục vụ bạn đọc.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card p-4 text-center h-100 border-0 shadow-sm">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-bolt"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Đăng ký mượn nhanh</h5>
                <p class="text-muted mb-0">Chỉ với vài click, bạn đã hoàn tất đăng ký mượn cuốn sách yêu thích trực tuyến.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card p-4 text-center h-100 border-0 shadow-sm">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Hỗ trợ chu đáo</h5>
                <p class="text-muted mb-0">Hệ thống luôn đồng hành hỗ trợ, nhắc hạn trả sách tự động qua email, thông báo.</p>
            </div>
        </div>
    </div>

    <!-- Featured Books -->
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
            <div>
                <h2 class="section-title mb-1"><i class="fas fa-award text-warning me-2"></i>Sách nổi bật</h2>
                <p class="text-muted mb-0 small">Những cuốn sách được bạn đọc yêu thích nhất tuần qua</p>
            </div>
            <a href="/Home/Books" class="btn btn-outline-primary btn-sm px-3 py-2 fw-semibold" style="border-radius: 6px;">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
        </div>

        <div class="row">
            @if (ViewBag.FeaturedBooks != null && ((dynamic)ViewBag.FeaturedBooks).Count > 0)
            {
                @foreach (var sach in ViewBag.FeaturedBooks)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="card book-card h-100 shadow-sm border-0">
                            <div class="book-cover-container">
                                @if (!string.IsNullOrEmpty(sach.HinhAnh))
                                {
                                    <img src="@sach.HinhAnh" class="book-cover-img" alt="@sach.TenSach">
                                }
                                else
                                {
                                    <div style="height: 330px; background: #e9ecef; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <h5 class="book-title" title="@sach.TenSach">@sach.TenSach</h5>
                                <p class="card-text text-muted mb-2 small"><i class="fas fa-pen-nib me-1"></i> @sach.TacGia?.TenTacGia</p>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                    <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                    <small class="text-success fw-bold" style="font-size: 0.95rem;">@sach.GiaTien.ToString("N0") đ</small>
                                </div>
                                <div class="mt-3">
                                    <a href="/DocGia/ChiTietSach/@sach.MaSach" class="btn btn-outline-primary btn-sm w-100 py-2 fw-semibold" style="border-radius: 6px;">
                                        <i class="fas fa-info-circle me-1"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có sách nào nổi bật</p>
                </div>
            }
        </div>
    </div>

    <!-- Books by Category: Văn học -->
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
            <div>
                <h2 class="section-title mb-1"><i class="fas fa-feather text-primary me-2"></i>Tinh Hoa Văn Học</h2>
                <p class="text-muted mb-0 small">Khám phá tâm hồn qua những áng văn học bất hủ</p>
            </div>
            <a href="/Home/Books?category=1" class="btn btn-outline-secondary btn-sm px-3 py-2 fw-semibold" style="border-radius: 6px;">Xem chủ đề <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
        <div class="row">
            @if (ViewBag.VanHocBooks != null && ((dynamic)ViewBag.VanHocBooks).Count > 0)
            {
                @foreach (var sach in ViewBag.VanHocBooks)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="card book-card h-100 shadow-sm border-0">
                            <div class="book-cover-container">
                                @if (!string.IsNullOrEmpty(sach.HinhAnh))
                                {
                                    <img src="@sach.HinhAnh" class="book-cover-img" alt="@sach.TenSach">
                                }
                                else
                                {
                                    <div style="height: 330px; background: #e9ecef; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <h5 class="book-title" title="@sach.TenSach">@sach.TenSach</h5>
                                <p class="card-text text-muted mb-2 small"><i class="fas fa-pen-nib me-1"></i> @sach.TacGia?.TenTacGia</p>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                    <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                    <small class="text-success fw-bold" style="font-size: 0.95rem;">@sach.GiaTien.ToString("N0") đ</small>
                                </div>
                                <div class="mt-3">
                                    <a href="/DocGia/ChiTietSach/@sach.MaSach" class="btn btn-outline-primary btn-sm w-100 py-2 fw-semibold" style="border-radius: 6px;">
                                        <i class="fas fa-info-circle me-1"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có sách văn học nào</p>
                </div>
            }
        </div>
    </div>

    <!-- Books by Category: Khoa học -->
    <div class="mb-5">
        <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
            <div>
                <h2 class="section-title mb-1"><i class="fas fa-atom text-info me-2"></i>Tri Thức Khoa Học</h2>
                <p class="text-muted mb-0 small">Khai phá bí ẩn của tự nhiên, kinh tế và vũ trụ</p>
            </div>
            <a href="/Home/Books?category=2" class="btn btn-outline-secondary btn-sm px-3 py-2 fw-semibold" style="border-radius: 6px;">Xem chủ đề <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
        <div class="row">
            @if (ViewBag.KhoaHocBooks != null && ((dynamic)ViewBag.KhoaHocBooks).Count > 0)
            {
                @foreach (var sach in ViewBag.KhoaHocBooks)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="card book-card h-100 shadow-sm border-0">
                            <div class="book-cover-container">
                                @if (!string.IsNullOrEmpty(sach.HinhAnh))
                                {
                                    <img src="@sach.HinhAnh" class="book-cover-img" alt="@sach.TenSach">
                                }
                                else
                                {
                                    <div style="height: 330px; background: #e9ecef; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                                    </div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <h5 class="book-title" title="@sach.TenSach">@sach.TenSach</h5>
                                <p class="card-text text-muted mb-2 small"><i class="fas fa-pen-nib me-1"></i> @sach.TacGia?.TenTacGia</p>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                    <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                    <small class="text-success fw-bold" style="font-size: 0.95rem;">@sach.GiaTien.ToString("N0") đ</small>
                                </div>
                                <div class="mt-3">
                                    <a href="/DocGia/ChiTietSach/@sach.MaSach" class="btn btn-outline-primary btn-sm w-100 py-2 fw-semibold" style="border-radius: 6px;">
                                        <i class="fas fa-info-circle me-1"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có sách khoa học nào</p>
                </div>
            }
        </div>
    </div>

    <!-- CTA Section - Modern Gradient Banner -->
    <div class="cta-banner text-center py-5 px-4 mb-4 text-white shadow">
        <div class="position-relative" style="z-index: 2; max-width: 650px; margin: 0 auto;">
            <h3 class="fw-bold mb-3" style="font-size: 2rem; letter-spacing: 0.5px;">Bắt đầu hành trình đọc sách ngay hôm nay</h3>
            <p class="text-white-50 mb-4 fs-5" style="font-weight: 300;">Đăng ký tài khoản độc giả hoàn toàn miễn phí để đăng ký mượn sách trực tuyến và nhận thông báo hạn trả kịp thời.</p>
            @if (Context.Session.GetString("MaNguoiDung") == null)
            {
                <a href="/Auth/Login" class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary shadow-sm" style="border-radius: 8px;">
                    <i class="fas fa-user-plus me-2"></i>Đăng ký Thành Viên ngay
                </a>
            }
            else
            {
                <a href="/DocGia/Dashboard" class="btn btn-warning btn-lg px-5 py-3 fw-bold text-white shadow-sm" style="border-radius: 8px;">
                    <i class="fas fa-chart-line me-2"></i>Xem Dashboard của bạn
                </a>
            }
        </div>
    </div>
</div>