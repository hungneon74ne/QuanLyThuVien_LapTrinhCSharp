    <!-- CTA Section -->
    <div class="text-center py-5" style="background: #003366; border-radius: 0;">
        <h3 class="text-white fw-bold mb-3">Bắt đầu khám phá ngay hôm nay</h3>
        <p class="text-white-50 mb-4">Đăng ký thành viên để mượn sách và nhận nhiều ưu đãi</p>
        @if (Context.Session.GetString("MaNguoiDung") == null)
        {
            <a href="/Auth/Login" class="btn btn-light btn-lg px-5 py-3 fw-bold">
                <i class="fas fa-user-plus me-2"></i>Đăng ký ngay
            </a>
        }
