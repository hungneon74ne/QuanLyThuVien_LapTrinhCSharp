@model IEnumerable<QuanLyThuVien.Models.Sach>
@{
    ViewData["Title"] = "Danh sách sách";
}

<div class="main-container">
    <!-- Search and Filter -->
    <form asp-action="Books" method="get" class="mb-5">
        <div class="row g-3">
            <div class="col-md-8">
                <div class="input-group">
                    <input type="text" class="form-control form-control-lg border-0 shadow-sm" placeholder="Tìm kiếm sách theo tên, tác giả..." name="keyword" value="@ViewBag.Keyword" style="border-radius: 8px 0 0 8px;">
                    <button class="btn btn-lg px-4" type="submit" style="background: #003366; color: white; border: none; border-radius: 0 8px 8px 0;">
                        <i class="fas fa-search"></i> Tìm kiếm
                    </button>
                </div>
            </div>
            <div class="col-md-4">
                <select class="form-select form-select-lg border-0 shadow-sm" name="category" onchange="this.form.submit()" style="border-radius: 8px;">
                    <option value="">Tất cả thể loại</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            if (ViewBag.SelectedCategory != null && (int)ViewBag.SelectedCategory == cat.MaTheLoai)
                            {
                                <option value="@cat.MaTheLoai" selected>@cat.TenTheLoai</option>
                            }
                            else
                            {
                                <option value="@cat.MaTheLoai">@cat.TenTheLoai</option>
                            }
                        }
                    }
                </select>
            </div>
        </div>
    </form>

    <!-- Books Grid -->
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var sach in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="card book-card h-100 shadow-sm border-0" style="transition: transform 0.2s, box-shadow 0.2s; border-radius: 12px; overflow: hidden;">
                        @if (!string.IsNullOrEmpty(sach.HinhAnh))
                        {
                            <img src="@sach.HinhAnh" class="card-img-top" alt="@sach.TenSach" style="height: 320px; object-fit: cover;">
                        }
                        else
                        {
                            <div style="height: 320px; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-book text-muted" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column p-3">
                            <h5 class="card-title fw-bold" style="font-size: 1.05rem; min-height: 48px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;" title="@sach.TenSach">@sach.TenSach</h5>
                            <p class="card-text text-muted mb-2 small"><i class="fas fa-pen-nib me-1"></i> @sach.TacGia?.TenTacGia</p>
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
                                <span class="badge bg-secondary">@sach.TheLoai?.TenTheLoai</span>
                                <small class="text-success fw-bold" style="font-size: 0.95rem;">@sach.GiaTien?.ToString("N0") đ</small>
                            </div>
                            <div class="mt-3">
                                <a href="/DocGia/ChiTietSach/@sach.MaSach" class="btn btn-outline-primary btn-sm w-100 py-2 fw-semibold" style="border-radius: 6px;">
                                    <i class="fas fa-info-circle me-1"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-search-minus fa-4x text-muted mb-3"></i>
                <h4 class="fw-bold text-muted">Không tìm thấy sách phù hợp</h4>
                <p class="text-muted">Hãy thử từ khóa khác hoặc lọc theo thể loại khác.</p>
                <a href="/Home/Books" class="btn btn-primary mt-2 px-4 py-2 fw-semibold" style="background: #003366; border: none; border-radius: 6px;">
                    <i class="fas fa-undo me-2"></i>Xem tất cả sách
                </a>
            </div>
        }
    </div>
</div>
