@model List<QuanLyThuVien.Models.VaiTroDocGia>
@{
    ViewData["Title"] = "Quản lý vai trò";
    Layout = "_ThuThuLayout";
    ViewBag.ActiveMenu = "QuanLyVaiTro";
}

<div class="card content-card">
    <div class="card-header content-header py-3">
        <h4 class="mb-0 fw-bold"><i class="fas fa-user-tag me-2"></i>Quản lý vai trò độc giả</h4>
    </div>
    <div class="card-body p-4">
        <div class="row mb-4">
            <div class="col-md-8 text-end">
                <button class="btn btn-success me-2" onclick="addVaiTro()">
                    <i class="fas fa-plus me-1"></i>Thêm vai trò
                </button>
                <button class="btn btn-secondary" onclick="refreshData()">
                    <i class="fas fa-sync me-1"></i>Làm mới
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã vai trò</th>
                        <th>Tên vai trò</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var vt in Model)
                        {
                            <tr>
                                <td class="fw-bold">VT@(vt.MaVaiTro.ToString("D3"))</td>
                                <td>@vt.TenVaiTro</td>
                                <td>
                                    <button class="btn btn-sm btn-primary me-1" onclick="editVaiTro(@vt.MaVaiTro)">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteVaiTro(@vt.MaVaiTro)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <i class="fas fa-user-tag fa-2x mb-2 text-light"></i>
                                <p>Không có vai trò nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="vaiTroModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="vaiTroModalTitle">Thêm vai trò</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="vaiTroForm">
                    <input type="hidden" id="maVaiTro" />
                    <div class="mb-3">
                        <label class="form-label">Tên vai trò *</label>
                        <input type="text" class="form-control" id="tenVaiTro" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="saveVaiTro()">Lưu</button>
            </div>
        </div>
    </div>
</div>

<script>
    let vaiTroModal;
    document.addEventListener('DOMContentLoaded', () => {
        vaiTroModal = new bootstrap.Modal(document.getElementById('vaiTroModal'));
    });

    function refreshData() {
        window.location.href = '/ThuThu/QuanLyVaiTro';
    }

    function addVaiTro() {
        document.getElementById('vaiTroModalTitle').textContent = 'Thêm vai trò';
        document.getElementById('vaiTroForm').reset();
        document.getElementById('maVaiTro').value = '';
        vaiTroModal.show();
    }

    async function editVaiTro(id) {
        const res = await fetch(`/ThuThu/GetVaiTroById?id=${id}`);
        const result = await res.json();
        if (!result.success) { showToast('Không tải được dữ liệu!', 'danger'); return; }
        document.getElementById('vaiTroModalTitle').textContent = 'Sửa vai trò';
        document.getElementById('maVaiTro').value = result.data.maVaiTro;
        document.getElementById('tenVaiTro').value = result.data.tenVaiTro || '';
        vaiTroModal.show();
    }

    function deleteVaiTro(id) {
        showConfirm('Bạn có chắc muốn xóa vai trò này không?', async () => {
            const result = await apiPost('/ThuThu/DeleteVaiTro', { id });
            if (result.success) { showToast(result.message, 'success'); setTimeout(refreshData, 1000); }
            else showToast(result.message || 'Lỗi!', 'danger');
        });
    }

    async function saveVaiTro() {
        const form = document.getElementById('vaiTroForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const result = await apiPost('/ThuThu/SaveVaiTro', {
            maVaiTro: parseInt(document.getElementById('maVaiTro').value) || 0,
            tenVaiTro: document.getElementById('tenVaiTro').value
        });
        if (result.success) { showToast(result.message, 'success'); vaiTroModal.hide(); setTimeout(refreshData, 1000); }
        else showToast(result.message || 'Lỗi!', 'danger');
    }
</script>
