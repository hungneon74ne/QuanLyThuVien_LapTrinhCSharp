@model List<QuanLyThuVien.Models.ChiTietPhieuMuon>
@{
    ViewData["Title"] = "Sách quá hạn";
    Layout = "_ThuThuLayout";
    ViewBag.ActiveMenu = "QuaHan";
}

<div class="card content-card">
    <div class="card-header content-header py-3">
        <h4 class="mb-0 fw-bold"><i class="fas fa-exclamation-triangle me-2"></i>Sách quá hạn</h4>
    </div>
    <div class="card-body p-4">
        @if (Model != null && Model.Any())
        {
            <div class="alert alert-danger mb-4">
                <i class="fas fa-exclamation-circle me-2"></i>
                Có <strong>@Model.Count</strong> phiếu mượn quá hạn cần xử lý.
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Hình ảnh</th>
                            <th>Mã phiếu</th>
                            <th>Người mượn</th>
                            <th>Sách</th>
                            <th>Ngày mượn</th>
                            <th>Hạn trả</th>
                            <th>Số ngày quá hạn</th>
                            <th>SĐT</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ct in Model)
                        {
                            var daysOverdue = (DateTime.Now - ct.PhieuMuon.HanTra.Value).Days;
                            <tr class="table-danger">
                                <td>
                                    @if (!string.IsNullOrEmpty(ct.Sach?.HinhAnh))
                                    {
                                        <img src="@ct.Sach.HinhAnh" alt="@ct.Sach.TenSach" style="width: 40px; height: 56px; object-fit: cover; border-radius: 4px;" />
                                    }
                                    else
                                    {
                                        <div style="width: 40px; height: 56px; background: #e0e0e0; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-book text-muted" style="font-size: 12px;"></i>
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold">PM@(ct.PhieuMuon?.MaPhieuMuon.ToString("D3"))</td>
                                <td>@ct.PhieuMuon?.DocGia?.NguoiDung?.HoTen</td>
                                <td class="fw-bold text-danger">@ct.Sach?.TenSach</td>
                                <td>@ct.PhieuMuon?.NgayMuon.ToString("dd/MM/yyyy")</td>
                                <td class="text-danger fw-bold">@ct.PhieuMuon?.HanTra?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge badge-danger fs-6">@daysOverdue ngày</span>
                                </td>
                                <td>@ct.PhieuMuon?.DocGia?.NguoiDung?.SoDienThoai</td>
                                <td>
                                    <a href="tel:@ct.PhieuMuon?.DocGia?.NguoiDung?.SoDienThoai" class="btn btn-sm btn-primary me-1">
                                        <i class="fas fa-phone"></i>
                                    </a>
                                    <a href="/ThuThu/TraSach?chiTietId=@ct.MaChiTiet" class="btn btn-sm btn-success">
                                        <i class="fas fa-undo me-1"></i>Xử lý trả
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-check-circle fa-4x mb-3 text-success"></i>
                <h5 class="text-success">Không có sách quá hạn</h5>
                <p class="text-muted">Tất cả sách đều được trả đúng hạn.</p>
            </div>
        }
    </div>
</div>
