@model List<QuanLyThuVien.Models.ChiTietPhieuMuon>
@{
    ViewData["Title"] = "Lịch sử mượn trả";
    Layout = "_ThuThuLayout";
    ViewBag.ActiveMenu = "LichSuMuonTra";
}

<div class="card content-card">
    <div class="card-header content-header py-3">
        <h4 class="mb-0 fw-bold"><i class="fas fa-history me-2"></i>Lịch sử mượn trả</h4>
    </div>
    <div class="card-body p-4">
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" class="form-control" id="searchInput" placeholder="Tìm kiếm...">
                    <button class="btn btn-primary" onclick="search()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-3">
                <input type="date" class="form-control" id="tuNgay">
            </div>
            <div class="col-md-3">
                <input type="date" class="form-control" id="denNgay">
            </div>
            <div class="col-md-2">
                <button class="btn btn-secondary w-100" onclick="refreshData()">
                    <i class="fas fa-sync"></i>
                </button>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Hình ảnh</th>
                            <th>Mã phiếu</th>
                            <th>Người mượn</th>
                            <th>Sách</th>
                            <th>Ngày mượn</th>
                            <th>Ngày trả</th>
                            <th>Tình trạng</th>
                            <th>Tiền phạt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ct in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(ct.Sach?.HinhAnh))
                                    {
                                        <img src="@ct.Sach.HinhAnh" alt="@ct.Sach.TenSach" style="width: 40px; height: 56px; object-fit: cover; border-radius: 4px;" />
                                    }
                                    else
                                    {
                                        <div style="width: 40px; height: 56px; background: #e0e0e0; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                                            <i class="fas fa-book text-muted" style="font-size: 12px;"></i>
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold">PM@(ct.PhieuMuon?.MaPhieuMuon.ToString("D3"))</td>
                                <td>@ct.PhieuMuon?.DocGia?.NguoiDung?.HoTen</td>
                                <td>@ct.Sach?.TenSach</td>
                                <td>@ct.PhieuMuon?.NgayMuon.ToString("dd/MM/yyyy")</td>
                                <td>@ct.PhieuTra?.NgayTra.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (ct.PhieuTra?.TinhTrangSach == 1)
                                    {
                                        <span class="badge badge-success">Tốt</span>
                                    }
                                    else if (ct.PhieuTra?.TinhTrangSach == 2)
                                    {
                                        <span class="badge badge-warning">Hư hỏng nhẹ</span>
                                    }
                                    else if (ct.PhieuTra?.TinhTrangSach == 3)
                                    {
                                        <span class="badge badge-danger">Hư hỏng nặng</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Mất sách</span>
                                    }
                                </td>
                                <td>@ct.PhieuTra?.TienPhat.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-history fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">Không có lịch sử mượn trả</h5>
            </div>
        }
    </div>
</div>

<script>
    function search() {
        const keyword = document.getElementById('searchInput').value;
        const tuNgay = document.getElementById('tuNgay').value;
        const denNgay = document.getElementById('denNgay').value;
        window.location.href = `/ThuThu/LichSuMuonTra?keyword=${keyword}&tuNgay=${tuNgay}&denNgay=${denNgay}`;
    }

    function refreshData() {
        window.location.href = '/ThuThu/LichSuMuonTra';
    }
</script>
