@model List<QuanLyThuVien.Models.DocGia>
@{
    ViewData["Title"] = "Quản lý độc giả";
    Layout = "_ThuThuLayout";
    ViewBag.ActiveMenu = "QuanLyDocGia";
}

<div class="card content-card">
    <div class="card-header content-header py-3">
        <h4 class="mb-0 fw-bold"><i class="fas fa-users me-2"></i>Quản lý độc giả</h4>
    </div>
    <div class="card-body p-4">
        <!-- Toolbar -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" class="form-control" id="searchInput" placeholder="Tìm kiếm độc giả...">
                    <button class="btn btn-primary" onclick="searchDocGia()">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
            <div class="col-md-8 text-end">
                <button class="btn btn-success me-2" onclick="addDocGia()">
                    <i class="fas fa-plus me-1"></i>Thêm độc giả
                </button>
                <button class="btn btn-secondary" onclick="refreshData()">
                    <i class="fas fa-sync me-1"></i>Làm mới
                </button>
            </div>
        </div>

        <!-- Data Grid -->
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã độc giả</th>
                        <th>Họ tên</th>
                        <th>SĐT</th>
                        <th>Email</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var dg in Model)
                        {
                            <tr>
                                <td class="fw-bold">DG@(dg.MaDocGia.ToString("D4"))</td>
                                <td>@dg.TenDocGia</td>
                                <td>@dg.SoDienThoai</td>
                                <td>@dg.Email</td>
                                <td><span class="badge bg-info">@dg.VaiTroDocGia?.TenVaiTro</span></td>
                                <td>
                                    @if (dg.NguoiDung?.TrangThai == QuanLyThuVien.Enums.TrangThaiTaiKhoan.HoatDong)
                                    {
                                        <span class="badge badge-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Khóa</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-primary me-1" onclick="editDocGia(@dg.MaDocGia)">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteDocGia(@dg.MaDocGia)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="fas fa-users fa-2x mb-2 text-light"></i>
                                <p>Không có độc giả nào.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Thêm/Sửa độc giả -->
<div class="modal fade" id="docGiaModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="docGiaModalTitle">Thêm độc giả mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="docGiaForm">
                    <input type="hidden" id="maDocGia" />
                    <input type="hidden" id="maNguoiDung" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Họ tên *</label>
                            <input type="text" class="form-control" id="hoTen" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giới tính</label>
                            <select class="form-select" id="gioiTinh">
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">SĐT *</label>
                            <input type="text" class="form-control" id="soDienThoai" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email *</label>
                            <input type="email" class="form-control" id="email" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày sinh</label>
                            <input type="date" class="form-control" id="ngaySinh">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">CCCD</label>
                            <input type="text" class="form-control" id="soCCCD">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" id="diaChi">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày bắt đầu *</label>
                            <input type="date" class="form-control" id="ngayBatDau" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày kết thúc</label>
                            <input type="date" class="form-control" id="ngayKetThuc">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vai trò *</label>
                        <select class="form-select" id="vaiTro" required>
                            <option value="">Chọn vai trò</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tên đăng nhập *</label>
                            <input type="text" class="form-control" id="tenDangNhap" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Mật khẩu *</label>
                            <input type="password" class="form-control" id="matKhau" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-select" id="trangThai">
                            <option value="1">Hoạt động</option>
                            <option value="0">Khóa</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" onclick="saveDocGia()">Lưu</button>
            </div>
        </div>
    </div>
</div>

<script>
    let docGiaModal;

    document.addEventListener('DOMContentLoaded', function() {
        docGiaModal = new bootstrap.Modal(document.getElementById('docGiaModal'));
        loadVaiTros();
    });

    async function loadVaiTros() {
        const res = await fetch('/ThuThu/GetVaiTros');
        const result = await res.json();
        if (!result.success) return;
        const select = document.getElementById('vaiTro');
        select.innerHTML = '<option value="">Chọn vai trò</option>';
        result.data.forEach(vt => {
            const opt = document.createElement('option');
            opt.value = vt.maVaiTro;
            opt.textContent = vt.tenVaiTro;
            select.appendChild(opt);
        });
    }

    function searchDocGia() { window.location.href = `/ThuThu/QuanLyDocGia?keyword=${document.getElementById('searchInput').value}`; }
    function refreshData() { window.location.href = '/ThuThu/QuanLyDocGia'; }

    function addDocGia() {
        document.getElementById('docGiaModalTitle').textContent = 'Thêm độc giả mới';
        document.getElementById('docGiaForm').reset();
        document.getElementById('maDocGia').value = '0';
        document.getElementById('matKhau').required = true;
        document.getElementById('tenDangNhap').readOnly = false;
        docGiaModal.show();
    }

    async function editDocGia(id) {
        const res = await fetch(`/ThuThu/GetDocGiaById?id=${id}`);
        const result = await res.json();
        if (!result.success) { showToast('Không tải được dữ liệu!', 'danger'); return; }
        const d = result.data;
        document.getElementById('docGiaModalTitle').textContent = 'Sửa độc giả';
        document.getElementById('maDocGia').value = d.maDocGia;
        document.getElementById('hoTen').value = d.tenDocGia || '';
        document.getElementById('gioiTinh').value = d.gioiTinh || 'Nam';
        document.getElementById('soDienThoai').value = d.soDienThoai || '';
        document.getElementById('email').value = d.email || '';
        document.getElementById('ngaySinh').value = d.ngaySinh || '';
        document.getElementById('soCCCD').value = d.soCCCD || '';
        document.getElementById('diaChi').value = d.diaChi || '';
        document.getElementById('ngayBatDau').value = d.ngayBatDau || '';
        document.getElementById('ngayKetThuc').value = d.ngayKetThuc || '';
        document.getElementById('vaiTro').value = d.maVaiTro || '';
        document.getElementById('tenDangNhap').value = d.tenDangNhap || '';
        document.getElementById('tenDangNhap').readOnly = true;
        document.getElementById('matKhau').value = '';
        document.getElementById('matKhau').required = false;
        document.getElementById('trangThai').value = d.trangThai;
        docGiaModal.show();
    }

    function deleteDocGia(id) {
        showConfirm('Bạn có chắc muốn xóa độc giả này? Tài khoản sẽ bị khóa!', async () => {
            const result = await apiPost('/ThuThu/DeleteDocGia', { id });
            if (result.success) { showToast(result.message, 'success'); setTimeout(refreshData, 1000); }
            else showToast(result.message || 'Lỗi!', 'danger');
        });
    }

    async function saveDocGia() {
        const form = document.getElementById('docGiaForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const maDocGia = parseInt(document.getElementById('maDocGia').value) || 0;
        const result = await apiPost('/ThuThu/SaveDocGia', {
            maDocGia,
            hoTen: document.getElementById('hoTen').value,
            gioiTinh: document.getElementById('gioiTinh').value,
            soDienThoai: document.getElementById('soDienThoai').value,
            email: document.getElementById('email').value,
            ngaySinh: document.getElementById('ngaySinh').value || null,
            soCCCD: document.getElementById('soCCCD').value,
            diaChi: document.getElementById('diaChi').value,
            ngayBatDau: document.getElementById('ngayBatDau').value || null,
            ngayKetThuc: document.getElementById('ngayKetThuc').value || null,
            maVaiTro: parseInt(document.getElementById('vaiTro').value) || null,
            tenDangNhap: document.getElementById('tenDangNhap').value,
            matKhau: document.getElementById('matKhau').value || null,
            trangThai: parseInt(document.getElementById('trangThai').value)
        });
        if (result.success) { showToast(result.message, 'success'); docGiaModal.hide(); setTimeout(refreshData, 1000); }
        else showToast(result.message || 'Lỗi!', 'danger');
    }
</script>
