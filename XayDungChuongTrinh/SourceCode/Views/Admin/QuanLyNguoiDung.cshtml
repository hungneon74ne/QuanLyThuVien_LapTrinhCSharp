@model List<QuanLyThuVien.Models.NguoiDung>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "_AdminLayout";
    ViewBag.ActiveMenu = "QuanLyNguoiDung";
}

<div class="card content-card border-0">
    <div class="card-header content-header py-3">
        <h4 class="mb-0 fw-bold"><i class="fas fa-users-cog me-2"></i>Quản lý tài khoản hệ thống</h4>
    </div>
    <div class="card-body p-4">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="text-muted" style="font-size: 0.8rem; text-transform: uppercase; border-bottom: 2px solid #f0f0f0;">
                            <th class="ps-3">Người dùng</th>
                            <th>Tên đăng nhập</th>
                            <th>Liên hệ</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var initials = !string.IsNullOrEmpty(user.HoTen) ? user.HoTen.Substring(0, 1).ToUpper() : "U";
                            var avatarBg = user.Quyen == QuanLyThuVien.Enums.QuyenNguoiDung.Admin 
                                ? "linear-gradient(135deg, #e74c3c 0%, #c0392b 100%)" 
                                : "linear-gradient(135deg, #333333 0%, #444444 100%)";
                            <tr>
                                <td class="py-3 ps-3">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3 d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" 
                                             style="width: 44px; height: 44px; border-radius: 50%; background: @avatarBg; font-size: 1.15rem;">
                                            @initials
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark d-block" style="font-size: 0.95rem;">@user.HoTen</span>
                                            <small class="text-muted"><i class="far fa-id-badge me-1"></i>ID: ND@(user.MaNguoiDung.ToString("D3"))</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-semibold text-secondary">@user.TenDangNhap</td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-dark" style="font-size: 0.9rem;"><i class="fas fa-phone me-1 text-muted" style="font-size: 0.8rem;"></i> @(string.IsNullOrEmpty(user.SoDienThoai) ? "-" : user.SoDienThoai)</span>
                                        <span class="text-muted" style="font-size: 0.85rem;"><i class="fas fa-envelope me-1 text-muted" style="font-size: 0.8rem;"></i> @(string.IsNullOrEmpty(user.Email) ? "-" : user.Email)</span>
                                    </div>
                                </td>
                                <td>
                                    @if (user.Quyen == QuanLyThuVien.Enums.QuyenNguoiDung.Admin)
                                    {
                                        <span class="badge bg-danger px-3 py-2" style="border-radius: 30px; font-size: 0.75rem; font-weight: 600;"><i class="fas fa-user-shield me-1"></i>Admin</span>
                                    }
                                    else if (user.Quyen == QuanLyThuVien.Enums.QuyenNguoiDung.ThuThu)
                                    {
                                        <span class="badge bg-dark px-3 py-2 text-white" style="border-radius: 30px; font-size: 0.75rem; font-weight: 600;"><i class="fas fa-user-tie me-1 text-warning"></i>Thủ thư</span>
                                    }
                                </td>
                                <td>
                                    @if (user.TrangThai == QuanLyThuVien.Enums.TrangThaiTaiKhoan.HoatDong)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2" style="border-radius: 30px; font-size: 0.75rem; font-weight: 600;"><i class="fas fa-check-circle me-1"></i>Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2" style="border-radius: 30px; font-size: 0.75rem; font-weight: 600;"><i class="fas fa-minus-circle me-1"></i>Khóa</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (user.Quyen != QuanLyThuVien.Enums.QuyenNguoiDung.Admin)
                                    {
                                        <a href="/Admin/ToggleUserStatus/@user.MaNguoiDung" class="btn btn-sm px-3 py-2 fw-bold @(user.TrangThai == QuanLyThuVien.Enums.TrangThaiTaiKhoan.HoatDong ? "btn-outline-danger" : "btn-outline-success")" style="border-radius: 30px; font-size: 0.8rem; transition: all 0.2s ease;">
                                            <i class="fas fa-@(user.TrangThai == QuanLyThuVien.Enums.TrangThaiTaiKhoan.HoatDong ? "lock" : "unlock") me-1"></i>
                                            @(user.TrangThai == QuanLyThuVien.Enums.TrangThaiTaiKhoan.HoatDong ? "Khóa tài khoản" : "Mở tài khoản")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fw-semibold" style="letter-spacing: 0.5px;"><i class="fas fa-ban me-1"></i>Không thể khóa</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users-cog fa-4x mb-3 text-muted"></i>
                <h5 class="text-muted">Không có tài khoản nào</h5>
            </div>
        }
    </div>
</div>
