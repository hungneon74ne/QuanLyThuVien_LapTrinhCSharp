@model dynamic
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
    ViewBag.ActiveMenu = "Index";
}

<div class="card content-card border-0">
    <div class="card-header content-header py-3">
        <h4 class="mb-0 fw-bold"><i class="fas fa-tachometer-alt me-2"></i>Dashboard Admin</h4>
    </div>
    <div class="card-body p-4">
        <!-- Thống kê tổng quan -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; border-left: 4.5px solid #f1c40f !important;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1" style="font-weight: 500;">Tổng số sách</h6>
                                <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalSach</h3>
                            </div>
                            <div style="font-size: 2rem; color: #f1c40f;">
                                <i class="fas fa-book"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; border-left: 4.5px solid #2ecc71 !important;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1" style="font-weight: 500;">Tổng độc giả</h6>
                                <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalDocGia</h3>
                            </div>
                            <div style="font-size: 2rem; color: #2ecc71;">
                                <i class="fas fa-users"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; border-left: 4.5px solid #3498db !important;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1" style="font-weight: 500;">Thủ thư (Staff)</h6>
                                <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalThuThu</h3>
                            </div>
                            <div style="font-size: 2rem; color: #3498db;">
                                <i class="fas fa-user-tie"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; border-left: 4.5px solid #e74c3c !important;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1" style="font-weight: 500;">Phiếu quá hạn</h6>
                                <h3 class="fw-bold mb-0 text-dark">@ViewBag.TotalPhieuQuaHan</h3>
                            </div>
                            <div style="font-size: 2rem; color: #e74c3c;">
                                <i class="fas fa-exclamation-triangle"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top sách được mượn nhiều nhất -->
        <div class="row mb-4">
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-white py-3 border-0" style="border-bottom: 1px solid #f0f0f0 !important;">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-star me-2 text-warning"></i>Top 5 sách mượn nhiều nhất</h5>
                    </div>
                    <div class="card-body p-3">
                        @if (ViewBag.TopSach != null && ((dynamic)ViewBag.TopSach).Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr class="text-muted" style="font-size: 0.8rem; text-transform: uppercase;">
                                            <th>Sách</th>
                                            <th class="text-end">Số lần mượn</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in ViewBag.TopSach)
                                        {
                                            <tr>
                                                <td class="py-3">
                                                    <div class="d-flex align-items-center">
                                                        <img src="@(string.IsNullOrEmpty(item.Sach.HinhAnh) ? "/images/default-book.png" : item.Sach.HinhAnh)" 
                                                             alt="@item.Sach.TenSach" 
                                                             style="width: 42px; height: 58px; object-fit: cover; border-radius: 6px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);" 
                                                             class="me-3">
                                                        <div>
                                                            <span class="fw-bold text-dark d-block" style="font-size: 0.95rem;">@item.Sach.TenSach</span>
                                                            <small class="text-muted"><i class="fas fa-barcode me-1"></i>ISBN: @(string.IsNullOrEmpty(item.Sach.ISBN) ? "N/A" : item.Sach.ISBN)</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-end fw-bold text-dark fs-5 align-middle">@item.Count <span class="text-muted" style="font-size: 0.75rem; font-weight: normal;">lượt</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-book-open fa-3x mb-3 text-muted" style="opacity: 0.3;"></i>
                                <p class="text-muted mb-0">Chưa có dữ liệu thống kê</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-white py-3 border-0" style="border-bottom: 1px solid #f0f0f0 !important;">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-user-graduate me-2 text-info"></i>Top 5 độc giả mượn nhiều nhất</h5>
                    </div>
                    <div class="card-body p-3">
                        @if (ViewBag.TopDocGia != null && ((dynamic)ViewBag.TopDocGia).Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr class="text-muted" style="font-size: 0.8rem; text-transform: uppercase;">
                                            <th>Độc giả</th>
                                            <th class="text-end">Số lần mượn</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in ViewBag.TopDocGia)
                                        {
                                            var initials = !string.IsNullOrEmpty(item.DocGia.TenDocGia) ? item.DocGia.TenDocGia.Substring(0, 1).ToUpper() : "U";
                                            <tr>
                                                <td class="py-3">
                                                    <div class="d-flex align-items-center">
                                                        <div class="me-3 d-flex align-items-center justify-content-center fw-bold text-white shadow-sm" 
                                                             style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #3498db 0%, #2980b9 100%); font-size: 1.1rem;">
                                                            @initials
                                                        </div>
                                                        <div>
                                                            <span class="fw-bold text-dark d-block" style="font-size: 0.95rem;">@item.DocGia.TenDocGia</span>
                                                            <small class="text-muted"><i class="fas fa-envelope me-1"></i>@(string.IsNullOrEmpty(item.DocGia.Email) ? "N/A" : item.DocGia.Email)</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-end fw-bold text-dark fs-5 align-middle">@item.Count <span class="text-muted" style="font-size: 0.75rem; font-weight: normal;">lượt</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-users fa-3x mb-3 text-muted" style="opacity: 0.3;"></i>
                                <p class="text-muted mb-0">Chưa có dữ liệu thống kê</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Thống kê mượn trả theo tháng (Biểu đồ trực quan) -->
        <div class="row">
            <div class="col-md-12">
                <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                    <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid #f0f0f0 !important;">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-chart-bar me-2" style="color: #f1c40f;"></i>Xu hướng mượn trả sách theo tháng (@DateTime.Now.Year)</h5>
                        <span class="badge bg-light text-dark fw-bold border" style="font-size: 0.85rem;"><i class="far fa-clock me-1 text-warning"></i>Cập nhật thời gian thực</span>
                    </div>
                    <div class="card-body p-4" style="background: #fafafa;">
                        <div style="position: relative; height: 350px;">
                            <canvas id="borrowingChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const thongKeData = @Html.Raw(Json.Serialize(ViewBag.ThongKeThang));
        const labels = Array.from({length: 12}, (_, i) => `Tháng ${i + 1}`);
        const dataPoints = Array(12).fill(0);
        
        if (thongKeData && Array.isArray(thongKeData)) {
            thongKeData.forEach(item => {
                if (item.thang >= 1 && item.thang <= 12) {
                    dataPoints[item.thang - 1] = item.count;
                }
            });
        }

        const ctx = document.getElementById('borrowingChart').getContext('2d');
        
        // Gradient color for bars
        const gradient = ctx.createLinearGradient(0, 0, 0, 350);
        gradient.addColorStop(0, 'rgba(241, 196, 15, 0.85)'); // Vibrant Gold
        gradient.addColorStop(1, 'rgba(243, 156, 18, 0.15)'); // Warm Orange-Gold faded

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Số lượt mượn sách',
                    data: dataPoints,
                    backgroundColor: gradient,
                    borderColor: '#f1c40f',
                    borderWidth: 2,
                    borderRadius: 8,
                    borderSkipped: false,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: '#333',
                        titleColor: '#fff',
                        bodyColor: '#f1c40f',
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return ` ${context.parsed.y} lượt mượn`;
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            precision: 0,
                            color: '#64748b',
                            font: {
                                weight: 'bold'
                            }
                        },
                        grid: {
                            color: 'rgba(0,0,0,0.04)',
                            drawBorder: false
                        }
                    },
                    x: {
                        ticks: {
                            color: '#64748b',
                            font: {
                                weight: 'bold'
                            }
                        },
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    });
</script>
