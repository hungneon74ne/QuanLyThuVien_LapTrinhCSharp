@model QuanLyThuVien.Models.DocGia
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<style>
    .info-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        background: #fff;
    }
    .info-header {
        background: linear-gradient(135deg, #003366 0%, #00509e 100%);
        color: white;
        border-radius: 12px 12px 0 0;
        padding: 20px;
    }
    .form-label {
        font-weight: 600;
        color: #6c757d;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control:focus {
        border-color: #003366;
        box-shadow: 0 0 0 0.2rem rgba(0, 51, 102, 0.15);
    }
</style>

<div class="container-fluid py-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header border-0 py-3" style="background: #003366; color: white;">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-bars me-2"></i>Menu Độc Giả</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/Dashboard" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-home me-2"></i>Trang chủ
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3" style="background: rgba(0,51,102,0.05);">
                            <a href="/DocGia/ThongTinCaNhan" class="text-decoration-none fw-bold" style="color: #003366;">
                                <i class="fas fa-user me-2"></i>Thông tin cá nhân
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/DanhSachSach" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book me-2"></i>Danh sách sách
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/DanhSachDangMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book-open me-2"></i>Sách đang mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/LichSuMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-history me-2"></i>Lịch sử mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/SachYeuThich" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-heart me-2"></i>Sách yêu thích
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/NhanThongBao" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-bell me-2"></i>Thông báo
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/XemQuyDinhThuVien" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-info-circle me-2"></i>Quy định thư viện
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Cập nhật thông tin -->
            <div class="card info-card mb-4">
                <div class="info-header">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-user-edit me-2"></i>Cập nhật thông tin cá nhân</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/DocGia/CapNhatThongTinCaNhan" method="post">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label">Họ tên</label>
                                    <input type="text" class="form-control" name="tenDocGia" value="@Model?.TenDocGia" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label">Giới tính</label>
                                    <select class="form-control" name="gioiTinh">
                                        <option value="Nam" selected="@(Model?.GioiTinh == "Nam")">Nam</option>
                                        <option value="Nữ" selected="@(Model?.GioiTinh == "Nữ")">Nữ</option>
                                        <option value="Khác" selected="@(Model?.GioiTinh == "Khác")">Khác</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label">Ngày sinh</label>
                                    <input type="date" class="form-control" name="ngaySinh" value="@(Model?.NgaySinh?.ToString("yyyy-MM-dd"))">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label">Số điện thoại</label>
                                    <input type="text" class="form-control" name="soDienThoai" value="@Model?.SoDienThoai">
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email" value="@Model?.Email">
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Địa chỉ</label>
                            <textarea class="form-control" name="diaChi" rows="3">@Model?.DiaChi</textarea>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Số CCCD</label>
                            <input type="text" class="form-control" name="soCCCD" value="@Model?.SoCCCD">
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Vai trò</label>
                            <select class="form-control" name="maVaiTro">
                                @if (ViewBag.Roles != null)
                                {
                                    foreach (var role in (List<QuanLyThuVien.Models.VaiTroDocGia>)ViewBag.Roles)
                                    {
                                        <option value="@role.MaVaiTro" selected="@(Model?.MaVaiTro == role.MaVaiTro)">@role.TenVaiTro</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn fw-bold" style="background: #003366; color: white; border: none; border-radius: 8px; padding: 12px 24px;">
                            <i class="fas fa-save me-2"></i>Cập nhật thông tin
                        </button>
                    </form>
                </div>
            </div>

            <!-- Đổi mật khẩu -->
            <div class="card info-card mb-4">
                <div class="info-header">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-key me-2"></i>Đổi mật khẩu</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/DocGia/DoiMatKhau" method="post">
                        <div class="form-group mb-3">
                            <label class="form-label">Mật khẩu cũ</label>
                            <input type="password" class="form-control" name="matKhauCu" required>
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password" class="form-control" name="matKhauMoi" required>
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <input type="password" class="form-control" name="xacNhanMatKhauMoi" required>
                        </div>
                        <button type="submit" class="btn btn-warning fw-bold" style="border: none; border-radius: 8px; padding: 12px 24px;">
                            <i class="fas fa-sync-alt me-2"></i>Đổi mật khẩu
                        </button>
                    </form>
                </div>
            </div>

            <!-- Đăng xuất -->
            <div class="card info-card">
                <div class="card-body p-4">
                    <a href="/Auth/Logout" class="btn btn-danger w-100 fw-bold" style="border: none; border-radius: 8px; padding: 12px 24px;">
                        <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
