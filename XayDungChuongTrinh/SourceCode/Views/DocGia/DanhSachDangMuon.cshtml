@model List<QuanLyThuVien.Models.ChiTietPhieuMuon>
@{
    ViewData["Title"] = "Sách đang mượn";
}

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header border-0 py-3" style="background: #003366; color: white;">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-bars me-2"></i>Menu Độc Giả</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/Dashboard" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-home me-2"></i>Trang chủ
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/ThongTinCaNhan" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-user me-2"></i>Thông tin cá nhân
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/Home/Books" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book me-2"></i>Danh sách sách
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3" style="background: rgba(0,51,102,0.05);">
                            <a href="/DocGia/DanhSachDangMuon" class="text-decoration-none fw-bold" style="color: #003366;">
                                <i class="fas fa-book-open me-2"></i>Sách đang mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/LichSuMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-history me-2"></i>Lịch sử mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/SachYeuThich" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-heart me-2"></i>Sách yêu thích
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/XemQuyDinhThuVien" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-info-circle me-2"></i>Quy định thư viện
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 10px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h4 class="fw-bold text-dark"><i class="fas fa-book-reader text-success me-2"></i>Sách đang mượn</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info border-0 shadow-sm" style="border-radius: 8px;">
                        <i class="fas fa-info-circle me-2 text-info"></i><strong>Lưu ý:</strong> Vui lòng trả sách đúng hạn tại quầy thư viện để tránh phát sinh phí phạt quá hạn.
                    </div>

                    @if (ViewBag.OverdueBooksCount != null && (int)ViewBag.OverdueBooksCount > 0)
                    {
                        <div class="alert alert-danger border-0 shadow-sm mt-3" style="border-radius: 8px;">
                            <i class="fas fa-exclamation-triangle me-2 text-danger"></i><strong>Cảnh báo:</strong> Bạn có <span class="fw-bold">@ViewBag.OverdueBooksCount</span> cuốn sách đã quá hạn trả! Vui lòng hoàn trả ngay.
                        </div>
                    }

                    <div class="table-responsive mt-3">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr class="text-muted" style="font-size: 0.9rem;">
                                    <th>Mã phiếu</th>
                                    <th>Tên sách</th>
                                    <th>Tác giả</th>
                                    <th>Ngày mượn</th>
                                    <th>Hạn trả</th>
                                    <th class="text-end">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var ct in Model)
                                    {
                                        bool isOverdue = ct.PhieuMuon.HanTra.HasValue && ct.PhieuMuon.HanTra.Value < DateTime.Now;
                                        <tr>
                                            <td class="fw-bold">PM@(ct.PhieuMuon.MaPhieuMuon.ToString("D3"))</td>
                                            <td class="fw-bold">@ct.Sach.TenSach</td>
                                            <td>@(ct.Sach.TacGia?.TenTacGia ?? "Chưa rõ")</td>
                                            <td>@ct.PhieuMuon.NgayMuon.ToString("dd/MM/yyyy")</td>
                                            <td class="@(isOverdue ? "text-danger fw-bold" : "")">@ct.PhieuMuon.HanTra?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-end">
                                                @if (isOverdue)
                                                {
                                                    <span class="badge bg-danger">Quá hạn</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Đang mượn</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <i class="fas fa-book-open fa-3x text-muted mb-3"></i>
                                            <p class="text-muted mb-0">Bạn hiện không mượn cuốn sách nào.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Tiền phạt -->
            <div class="card border-0 shadow-sm" style="border-radius: 10px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold text-dark"><i class="fas fa-hand-holding-dollar text-warning me-2"></i>Tiền phạt quá hạn</h5>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted">Xem lịch sử chi tiết và số tiền phạt quá hạn tích lũy của các lần mượn trước.</p>
                    <a href="/DocGia/LichSuMuon" class="btn btn-warning px-4 text-dark fw-bold"><i class="fas fa-dollar-sign me-1"></i> Xem chi tiết tiền phạt</a>
                </div>
            </div>
        </div>
    </div>
</div>
