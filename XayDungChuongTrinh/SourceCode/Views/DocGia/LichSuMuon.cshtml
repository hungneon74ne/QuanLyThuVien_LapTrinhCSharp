@model List<QuanLyThuVien.Models.ChiTietPhieuMuon>
@{
    ViewData["Title"] = "Lịch sử mượn";
}

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header-premium border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-bars me-2"></i>Menu Độc Giả</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/Dashboard" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-home me-2"></i>Trang chủ
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/ThongTinCaNhan" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-user me-2"></i>Thông tin cá nhân
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/Home/Books" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book me-2"></i>Danh sách sách
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/DanhSachDangMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book-open me-2"></i>Sách đang mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3 list-group-item-active-gold">
                            <a href="/DocGia/LichSuMuon" class="text-decoration-none fw-bold">
                                <i class="fas fa-history me-2"></i>Lịch sử mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/SachYeuThich" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-heart me-2"></i>Sách yêu thích
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/XemQuyDinhThuVien" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-info-circle me-2"></i>Quy định thư viện
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header-premium border-0 py-3 text-white">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-history me-2"></i>Lịch sử mượn trả sách</h4>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr class="text-muted" style="font-size: 0.9rem;">
                                    <th>Mã phiếu</th>
                                    <th>Tên sách</th>
                                    <th>Ngày mượn</th>
                                    <th>Hạn trả</th>
                                    <th>Ngày trả</th>
                                    <th>Trạng thái</th>
                                    <th>Tiền phạt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var ct in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold">PM@(ct.PhieuMuon.MaPhieuMuon.ToString("D3"))</td>
                                            <td class="fw-bold">@(ct.Sach?.TenSach ?? "Chưa rõ")</td>
                                            <td>@ct.PhieuMuon.NgayMuon.ToString("dd/MM/yyyy")</td>
                                            <td>@ct.PhieuMuon.HanTra?.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                @(ct.TrangThaiTra == (int)QuanLyThuVien.Enums.TrangThaiTraSach.DaTra && ct.PhieuTra != null 
                                                    ? ct.PhieuTra.NgayTra.ToString("dd/MM/yyyy") 
                                                    : "-")
                                            </td>
                                            <td>
                                                @if (ct.TrangThaiTra == (int)QuanLyThuVien.Enums.TrangThaiTraSach.DaTra)
                                                {
                                                    <span class="badge bg-success">Đã trả</span>
                                                }
                                                else
                                                {
                                                    @if (ct.PhieuMuon.TrangThai == QuanLyThuVien.Enums.TrangThaiPhieuMuon.ChoDuyet)
                                                    {
                                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                                    }
                                                    else if (ct.PhieuMuon.TrangThai == QuanLyThuVien.Enums.TrangThaiPhieuMuon.TuChoi)
                                                    {
                                                        <span class="badge bg-danger">Từ chối</span>
                                                    }
                                                    else if (ct.PhieuMuon.TrangThai == QuanLyThuVien.Enums.TrangThaiPhieuMuon.DaHuy)
                                                    {
                                                        <span class="badge bg-dark">Đã hủy</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-info">Đang mượn</span>
                                                    }
                                                }
                                            </td>
                                            <td class="fw-bold @(ct.PhieuTra != null && ct.PhieuTra.TienPhat > 0 ? "text-danger" : "text-secondary")">
                                                @(ct.PhieuTra != null ? ct.PhieuTra.TienPhat.ToString("N0") + " VNĐ" : "0 VNĐ")
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5">
                                            <i class="far fa-folder-open fa-3x text-muted mb-3"></i>
                                            <p class="text-muted mb-0">Bạn chưa có lịch sử mượn trả nào.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Thống kê -->
                    <div class="row mt-4">
                        <div class="col-md-4 mb-3">
                            <div class="card border-0 shadow-sm text-white" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 8px;">
                                <div class="card-body p-4">
                                    <h6 class="card-title text-white-50"><i class="fas fa-book-reader me-1"></i> Tổng số lần mượn</h6>
                                    <p class="card-text display-5 fw-bold mb-0">@ViewBag.TongSoLanMuon</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card border-0 shadow-sm text-white" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); border-radius: 8px;">
                                <div class="card-body p-4">
                                    <h6 class="card-title text-white-50"><i class="fas fa-check-circle me-1"></i> Đã trả đúng hạn</h6>
                                    <p class="card-text display-5 fw-bold mb-0">@ViewBag.DaTraDungHan</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card border-0 shadow-sm text-white" style="background: linear-gradient(135deg, #f857a6 0%, #ff5858 100%); border-radius: 8px;">
                                <div class="card-body p-4">
                                    <h6 class="card-title text-white-50"><i class="fas fa-hand-holding-dollar me-1"></i> Tổng tiền phạt</h6>
                                    <p class="card-text display-5 fw-bold mb-0">@(((decimal)ViewBag.TongTienPhat).ToString("N0")) VNĐ</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
