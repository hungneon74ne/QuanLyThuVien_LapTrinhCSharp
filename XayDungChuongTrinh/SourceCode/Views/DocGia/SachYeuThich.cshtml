@model List<QuanLyThuVien.Models.Sach>
@{
    ViewData["Title"] = "Sách yêu thích";
}

<style>
    .book-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
        background: #fff;
    }
    .book-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }
    .book-cover-container {
        height: 240px;
        overflow: hidden;
        position: relative;
    }
    .book-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .book-card:hover .book-cover {
        transform: scale(1.05);
    }
    .card-title-link {
        color: #003366;
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        transition: color 0.3s;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-title-link:hover {
        color: #00509e;
    }
    .btn-detail {
        background: #f8f9fa;
        color: #003366;
        border: 1px solid #dee2e6;
        font-weight: 600;
        transition: all 0.3s;
    }
    .btn-detail:hover {
        background: #003366;
        color: white;
        border-color: #003366;
    }
    .btn-fav {
        color: #e74c3c;
        border: 1px solid #e74c3c;
        background: white;
        transition: all 0.3s;
    }
    .btn-fav:hover {
        background: #e74c3c;
        color: white;
    }
</style>

<div class="container-fluid py-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header border-0 py-3" style="background: #003366; color: white;">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-bars me-2"></i>Menu Độc Giả</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/Dashboard" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-home me-2"></i>Trang chủ
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/ThongTinCaNhan" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-user me-2"></i>Thông tin cá nhân
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/Home/Books" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book me-2"></i>Danh sách sách
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/DanhSachDangMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book-open me-2"></i>Sách đang mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/LichSuMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-history me-2"></i>Lịch sử mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3" style="background: rgba(0,51,102,0.05);">
                            <a href="/DocGia/SachYeuThich" class="text-decoration-none fw-bold" style="color: #003366;">
                                <i class="fas fa-heart me-2"></i>Sách yêu thích
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/XemQuyDinhThuVien" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-info-circle me-2"></i>Quy định thư viện
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                <div class="card-header border-0 py-3" style="background: linear-gradient(135deg, #003366 0%, #00509e 100%); color: white; border-radius: 12px 12px 0 0;">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-heart me-2"></i>Sách yêu thích (@Model.Count)</h4>
                </div>
                <div class="card-body p-4">
                    @if (Model != null && Model.Any())
                    {
                        <div class="row">
                            @foreach (var sach in Model)
                            {
                                <div class="col-lg-3 col-md-6 mb-4">
                                    <div class="card book-card h-100">
                                        <div class="book-cover-container">
                                            <a href="/DocGia/ChiTietSach/@sach.MaSach">
                                                <img src="@(string.IsNullOrEmpty(sach.HinhAnh) ? "/images/default-book.png" : sach.HinhAnh)" class="book-cover" alt="@sach.TenSach">
                                            </a>
                                        </div>
                                        <div class="card-body p-3">
                                            <h6 class="card-title fw-bold text-truncate" title="@sach.TenSach">
                                                <a href="/DocGia/ChiTietSach/@sach.MaSach" class="card-title-link">@sach.TenSach</a>
                                            </h6>
                                            <p class="text-muted small mb-2 text-truncate">@sach.TacGia?.TenTacGia</p>
                                            <p class="text-muted small mb-3">@sach.TheLoai?.TenTheLoai</p>
                                            <div class="d-flex gap-2">
                                                <a href="/DocGia/ChiTietSach/@sach.MaSach" class="btn btn-detail btn-sm flex-grow-1">Xem chi tiết</a>
                                                <button onclick="removeFavorite(@sach.MaSach)" class="btn btn-fav btn-sm">
                                                    <i class="fas fa-heart"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-heart-broken fa-4x text-muted mb-3"></i>
                            <h5 class="text-muted">Bạn chưa có sách yêu thích nào</h5>
                            <p class="text-muted">Hãy thêm sách vào danh sách yêu thích để dễ dàng tìm kiếm sau này.</p>
                            <a href="/Home/Books" class="btn btn-primary mt-3">
                                <i class="fas fa-book me-2"></i>Khám phá sách
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function removeFavorite(sachId) {
        Swal.fire({
            title: 'Xóa khỏi yêu thích?',
            text: "Bạn có chắc chắn muốn bỏ cuốn sách này khỏi danh sách yêu thích?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Đồng ý xóa',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/DocGia/XoaSachYeuThich', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ id: sachId })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Đã xóa thành công!',
                            text: 'Sách đã được loại bỏ khỏi danh sách yêu thích.',
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Thất bại',
                            text: data.message || 'Có lỗi xảy ra!'
                        });
                    }
                })
                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi kết nối',
                        text: 'Không thể kết nối tới máy chủ lúc này!'
                    });
                });
            }
        });
    }
</script>
