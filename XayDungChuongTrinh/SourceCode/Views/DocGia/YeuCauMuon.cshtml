@model List<QuanLyThuVien.Models.ChiTietPhieuMuon>
@{
    ViewData["Title"] = "Sách đang yêu cầu mượn";
}

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header-premium border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-bars me-2"></i>Menu Độc Giả</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/Dashboard" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-home me-2"></i>Trang chủ
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/ThongTinCaNhan" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-user me-2"></i>Thông tin cá nhân
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/DanhSachDangMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-book-open me-2"></i>Sách đang mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3 list-group-item-active-gold">
                            <a href="/DocGia/YeuCauMuon" class="text-decoration-none fw-bold">
                                <i class="fas fa-file-invoice me-2"></i>Sách yêu cầu mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/LichSuMuon" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-history me-2"></i>Lịch sử mượn
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/SachYeuThich" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-heart me-2"></i>Sách yêu thích
                            </a>
                        </li>
                        <li class="list-group-item border-0 py-3">
                            <a href="/DocGia/XemQuyDinhThuVien" class="text-decoration-none text-secondary hover-primary">
                                <i class="fas fa-info-circle me-2"></i>Quy định thư viện
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header-premium border-0 py-3 text-white">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-file-invoice me-2"></i>Sách đang yêu cầu mượn</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info border-0 shadow-sm" style="border-radius: 8px;">
                        <i class="fas fa-info-circle me-2 text-info"></i>Các yêu cầu này đang chờ **Thủ thư duyệt cấp sách**. Bạn có thể hủy yêu cầu mượn trước khi được duyệt duyệt.
                    </div>

                    <div class="table-responsive mt-3">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr class="text-muted" style="font-size: 0.9rem;">
                                    <th>Mã phiếu</th>
                                    <th>Thông tin Sách</th>
                                    <th>Tác giả</th>
                                    <th>Ngày yêu cầu</th>
                                    <th>Hạn duyệt tối đa</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var ct in Model)
                                    {
                                        <tr>
                                            <td class="fw-bold">PM@(ct.PhieuMuon.MaPhieuMuon.ToString("D3"))</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img src="@(string.IsNullOrEmpty(ct.Sach?.HinhAnh) ? "/images/default-book.png" : ct.Sach.HinhAnh)" 
                                                         alt="@(ct.Sach?.TenSach ?? "Chưa rõ")" 
                                                         style="width: 40px; height: 56px; object-fit: cover; border-radius: 6px; box-shadow: 0 2px 6px rgba(0,0,0,0.15);" 
                                                         class="me-3">
                                                    <div>
                                                        <span class="fw-bold text-dark d-block" style="font-size: 0.95rem;">@(ct.Sach?.TenSach ?? "Chưa rõ")</span>
                                                        <small class="text-muted"><i class="fas fa-barcode me-1"></i>ISBN: @(string.IsNullOrEmpty(ct.Sach?.ISBN) ? "N/A" : ct.Sach.ISBN)</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@(ct.Sach?.TacGia?.TenTacGia ?? "Chưa rõ")</td>
                                            <td class="text-secondary">@ct.PhieuMuon.NgayMuon.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-muted">@ct.PhieuMuon.NgayMuon.AddDays(3).ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <span class="badge bg-warning text-dark"><i class="far fa-clock me-1"></i>Chờ duyệt</span>
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger px-3 py-1.5" style="border-radius: 20px; font-weight: 600; font-size: 0.8rem;" onclick="huyYeuCau(@ct.PhieuMuon.MaPhieuMuon)">
                                                    <i class="fas fa-times me-1"></i> Hủy yêu cầu
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5">
                                            <i class="fas fa-file-invoice fa-3x text-muted mb-3" style="opacity: 0.35;"></i>
                                            <p class="text-muted mb-0">Bạn hiện không có yêu cầu mượn sách nào đang chờ duyệt.</p>
                                            <a href="/Home/Books" class="btn btn-premium-gold btn-sm mt-3 px-4 py-2" style="border-radius: 30px;"><i class="fas fa-search me-1"></i>Tìm sách để mượn</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
<script>
    function huyYeuCau(id) {
        Swal.fire({
            title: 'Hủy yêu cầu mượn?',
            text: "Bạn có chắc chắn muốn hủy yêu cầu mượn sách này?",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Đồng ý hủy',
            cancelButtonText: 'Không, giữ lại'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/DocGia/HuyYeuCauMuonSach', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ id: id })
                })
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            text: res.message,
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Thất bại',
                            text: res.message
                        });
                    }
                })
                .catch(() => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: 'Không thể thực hiện yêu cầu.'
                    });
                });
            }
        });
    }
</script>
